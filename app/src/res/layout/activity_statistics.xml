<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F7FA">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- 헤더 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingTop="12dp"
            android:paddingBottom="20dp">

            <TextView
                android:id="@+id/btnBack"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="‹"
                android:textSize="34sp"
                android:textStyle="bold"
                android:textColor="#1A1A2E"
                android:paddingEnd="12dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="물류 통계"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="#1A1A2E"/>
        </LinearLayout>

        <!-- 날짜 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_card_white"
            android:elevation="2dp"
            android:padding="16dp"
            android:layout_marginBottom="14dp">

            <TextView
                android:id="@+id/tvSelectedDate"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="2026-05-07"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#1A1A2E"/>

            <TextView
                android:id="@+id/btnSelectDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📅 날짜 선택"
                android:textSize="13sp"
                android:textColor="#4361EE"
                android:textStyle="bold"/>
        </LinearLayout>

        <!-- 전체 (강조 카드) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card_blue"
            android:elevation="3dp"
            android:padding="24dp"
            android:layout_marginBottom="14dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="전체 택배 수"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:alpha="0.9"/>

            <TextView
                android:id="@+id/tvTotal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="40sp"
                android:layout_marginTop="4dp"/>
        </LinearLayout>

        <!-- 상태별 통계 (2x2 그리드) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="10dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="@drawable/bg_card_white"
                android:elevation="2dp"
                android:padding="18dp"
                android:layout_marginEnd="5dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="접수 완료"
                    android:textSize="13sp"
                    android:textColor="#666666"/>

                <TextView
                    android:id="@+id/tvReady"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textSize="26sp"
                    android:textStyle="bold"
                    android:textColor="#4361EE"
                    android:layout_marginTop="2dp"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="@drawable/bg_card_white"
                android:elevation="2dp"
                android:padding="18dp"
                android:layout_marginStart="5dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="분류중"
                    android:textSize="13sp"
                    android:textColor="#666666"/>

                <TextView
                    android:id="@+id/tvSorting"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textSize="26sp"
                    android:textStyle="bold"
                    android:textColor="#FFB703"
                    android:layout_marginTop="2dp"/>
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="20dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="@drawable/bg_card_white"
                android:elevation="2dp"
                android:padding="18dp"
                android:layout_marginEnd="5dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="배송중"
                    android:textSize="13sp"
                    android:textColor="#666666"/>

                <TextView
                    android:id="@+id/tvShipping"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textSize="26sp"
                    android:textStyle="bold"
                    android:textColor="#06D6A0"
                    android:layout_marginTop="2dp"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="@drawable/bg_card_white"
                android:elevation="2dp"
                android:padding="18dp"
                android:layout_marginStart="5dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="배송 완료"
                    android:textSize="13sp"
                    android:textColor="#666666"/>

                <TextView
                    android:id="@+id/tvComplete"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textSize="26sp"
                    android:textStyle="bold"
                    android:textColor="#888888"
                    android:layout_marginTop="2dp"/>
            </LinearLayout>
        </LinearLayout>

        <!-- 구역별 통계 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="구역별 통계"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#1A1A2E"
            android:layout_marginBottom="12dp"/>

        <!-- A B -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="10dp">

            <TextView
                android:id="@+id/tvZoneA"
                android:layout_width="0dp"
                android:layout_height="64dp"
                android:layout_weight="1"
                android:text="A구역: 0건"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#4361EE"
                android:gravity="center"
                android:background="@drawable/bg_card_white"
                android:elevation="2dp"
                android:layout_marginEnd="5dp"/>

            <TextView
                android:id="@+id/tvZoneB"
                android:layout_width="0dp"
                android:layout_height="64dp"
                android:layout_weight="1"
                android:text="B구역: 0건"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#3A86FF"
                android:gravity="center"
                android:background="@drawable/bg_card_white"
                android:elevation="2dp"
                android:layout_marginStart="5dp"/>
        </LinearLayout>

        <!-- C D -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="10dp">

            <TextView
                android:id="@+id/tvZoneC"
                android:layout_width="0dp"
                android:layout_height="64dp"
                android:layout_weight="1"
                android:text="C구역: 0건"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#06D6A0"
                android:gravity="center"
                android:background="@drawable/bg_card_white"
                android:elevation="2dp"
                android:layout_marginEnd="5dp"/>

            <TextView
                android:id="@+id/tvZoneD"
                android:layout_width="0dp"
                android:layout_height="64dp"
                android:layout_weight="1"
                android:text="D구역: 0건"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#FFB703"
                android:gravity="center"
                android:background="@drawable/bg_card_white"
                android:elevation="2dp"
                android:layout_marginStart="5dp"/>
        </LinearLayout>

        <!-- E F -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="20dp">

            <TextView
                android:id="@+id/tvZoneE"
                android:layout_width="0dp"
                android:layout_height="64dp"
                android:layout_weight="1"
                android:text="E구역: 0건"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#FB5607"
                android:gravity="center"
                android:background="@drawable/bg_card_white"
                android:elevation="2dp"
                android:layout_marginEnd="5dp"/>

            <TextView
                android:id="@+id/tvZoneF"
                android:layout_width="0dp"
                android:layout_height="64dp"
                android:layout_weight="1"
                android:text="F구역: 0건"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#8338EC"
                android:gravity="center"
                android:background="@drawable/bg_card_white"
                android:elevation="2dp"
                android:layout_marginStart="5dp"/>
        </LinearLayout>

        <!-- 차트 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="구역별 차트"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#1A1A2E"
            android:layout_marginBottom="12dp"/>

        <com.github.mikephil.charting.charts.BarChart
            android:id="@+id/barChartZone"
            android:layout_width="match_parent"
            android:layout_height="260dp"
            android:background="@drawable/bg_card_white"
            android:elevation="2dp"
            android:padding="14dp"/>

    </LinearLayout>
</ScrollView>
